{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "serve-love-card",
      "type": "shell",
      "command": "python3",
      "args": [
        "-m",
        "http.server",
        "8080",
        "--bind",
        "127.0.0.1",
        "--directory",
        "${workspaceFolder}"
      ],
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": "."
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Serving HTTP on",
          "endsPattern": "GET / "
        }
      }
    }
  ]
}
